  <History Date="13-06-12" Author="Peter Budd" Comment="Created" Version="1" />
  <History Date="23-08-12" Author="Peter Budd" Comment="Created from Terbly OV370Z-R" Version="2" />
  <History Date="28-08-12" Author="Peter Budd" Comment="Created from Elation Platinum Wash ZXF Pro XL" Version="3" />
  <History Date="28-08-12" Author="Peter Budd" Comment="Created from Clay Paky A.leda K20" Version="4" />
  <History Date="30-10-12" Author="Peter Budd" Comment="Edited extended mode to include cell layout. Added RGBW master channels and added attribute links to RGBW cells" Version="5" />
  <History Date="27-10-13" Author="Nic Morris" Comment="Increased 16-bit functions to 2dp.  Standardised shutted function order." Version="6" />
  <History Date="27-10-13" Author="Nic Morris" Comment="Added detailed functions to Colour Macro and Function attributes." Version="7" />
  <History Date="27-10-13" Author="Nic Morris" Comment="Fixed shape mode.  Added Extended RGBW mode." Version="8" />
  <History Date="27-10-13" Author="Nic Morris" Comment="Created from Clay Paky A.leda Wash K10" Version="9" />
  <History Date="11-02-14" Author="RGB Power on Updater" Comment="Updated RGB Power on values to match Locate." Version="10" />
  <History Date="02-03-14" Author="Nic Morris" Comment="Added 'Full' mode and brought in line with latest spec." Version="11" />
  <History Date="08-06-14" Author="Nic Morris" Comment="Updated Shape strobe, Back strobe and back select to latest spec." Version="12" />
  <History Date="08-06-14" Author="Nic Morris" Comment="Updated shapes." Version="13" />
  <History Date="08-06-14" Author="Nic Morris" Comment="Added shape offset conditional functions for new shapes." Version="14" />
  <History Date="08-06-14" Author="Nic Morris" Comment="Revised wheel mappings and attribute groups." Version="15" />
  <History Date="08-06-14" Author="Nic Morris" Comment="Fixed lens rot CW spin range.  Changed lens rot spin display to value 1dp to provide full resolution." Version="16" />
  <History Date="02-01-15" Author="Nic Morris" Comment="Updated to 11.2014 spec" Version="17" />
  <History Date="24-11-15" Author="Nic Morris" Comment="Fixed extended mapping" Version="18" />
  <History Date="25-05-16" Author="AtlaBaseLibraryUpdater" Comment="Added AltaBase information" Version="19" />
  <History Date="29-06-16" Author="Nic Morris" Comment="Added Shape Control only mode and celled version of full Shapes mode." Version="20" />
  <History Date="29-08-16" Author="Nic Morris" Comment="Revised classic pearl refs" Version="21" />
  <History Date="04-09-16" Author="Nic Morris" Comment="Added missing Atlabase ID's." Version="22" />
  <History Date="15-05-18" Author="Nic Morris" Comment="Changed RGB masters to locate at zero." Version="23" />
  <History Date="26-09-18" Author="Peter Budd" Comment="Added and extra open range to the end of the shutter channel, and changed colour macro off to 0 instead of 0-9." Version="24" />
  <History Date="15-02-19" Author="Nic Morris" Comment="Added product thumbnail.  Added RDM ID's.  Added physical pan/tilt ranges." Version="25" />
  <History Date="15-02-19" Author="Nic Morris" Comment="Moved shape controls into effect group and wheel slot.  Moved colour macro into colour group and wheel slot." Version="26" />
  <History Date="26-05-20" Author="Nic Morris" Comment="Added vdim to all multi-celled modes in response to customer bug report.  Removed Atlabase ID from Shapes (cell version) to avoid conflict (duplicate)" Version="27" />
