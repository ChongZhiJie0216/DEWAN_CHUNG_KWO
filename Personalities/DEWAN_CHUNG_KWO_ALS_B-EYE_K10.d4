      <Function ID="2" Name="No Macro" Display="'No Macro'" Dmx="0~0" />
      <Function ID="3" Name="Random Flash" Display="'Random Flash %.1f%%',0.0~100.0" Dmx="10~255" />
      <Function ID="4" Name="Pixel Density" Display="'%.1f%%',0.0~100.0" Dmx="0~255" />
      <Function ID="5" Name="Index" Display="'%.f°',0~360" Dmx="0~255" />
      <Function ID="6" Name="Rand Dist" Display="'%.f',2~20" Dmx="0~255" />
      <Function ID="7" Name="Width" Display="'%.1f%%',0.0~100.0" Dmx="0~255" />
      <Function ID="8" Name="Offset" Display="'%.1f%%',0.0~100.0" Dmx="0~255" />
      <Function ID="9" Name="LEDs" Display="'%.1f%%',0.0~100.0" Dmx="0~255" />
    </Attribute>
    <Attribute ID="Lens_Func" Name="Lens Func" Description="" Group="B" Size="0">
